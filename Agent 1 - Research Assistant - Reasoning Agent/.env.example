APP_NAME=research-assistant-agent
LOG_LEVEL=INFO

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=papers
VECTOR_SIZE=1024
TOP_K=8

LLM_BASE_URL=http://host.docker.internal:9000/v1
LLM_API_KEY=change-me
LLM_MODEL=nemotron

EMBEDDING_BASE_URL=http://host.docker.internal:9001/v1
EMBEDDING_API_KEY=change-me
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

RERANK_BASE_URL=http://host.docker.internal:9002/v1
RERANK_API_KEY=change-me
RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3

ARXIV_API_URL=http://export.arxiv.org/api/query
SEMANTIC_SCHOLAR_API_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_API_URL=https://api.crossref.org/works
USER_AGENT=research-agent/1.0

BENCHMARK_CONCURRENCY=4
BENCHMARK_REQUESTS=20

MCP_HOST=0.0.0.0
MCP_PORT=8080
