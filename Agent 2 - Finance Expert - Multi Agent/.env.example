APP_ENV=local
DB_URL=sqlite:///./finance_agent.db
LOG_LEVEL=INFO
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=alerts@example.com
EMAIL_TO=

# News and market context
NEWS_LOOKBACK_DAYS=5
INDEX_SYMBOLS=^NSEI,^BSESN

# LLM selection: mock | openai_compatible | vertex_gemma
LLM_PROVIDER=mock
MACRO_MODEL_NAME=gemma-4-e4b-instruct
JUDGE_MODEL_NAME=gemma-4-31b-instruct
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=dummy
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_GEMMA_ENDPOINT_ID=

# Presidio
ENABLE_PRESIDIO=true

# App behavior
SEND_EMAIL_ONLY_FOR_BUY=false
BUY_THRESHOLD=70
WATCH_THRESHOLD=55
